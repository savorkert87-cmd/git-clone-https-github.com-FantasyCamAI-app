# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fantasycamai
SQLALCHEMY_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0

# FastAPI
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# Security
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256

# Frontend URLs
